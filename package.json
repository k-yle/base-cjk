{
  "name": "base-cjk",
  "version": "1.0.0",
  "author": "Kyle Hensel",
  "description": "BaseCJK is like Base64, but using CJK characters",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "repository": "https://github.com/k-yle/base-cjk",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown --exports --minify --format esm --format cjs",
    "lint": "eslint .",
    "test": "vitest && vitest bench"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-config-kyle": "^27.0.2",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": "eslint-config-kyle/prettier"
}
